# ===================================================================
# ASR API 環境變數範本
# ===================================================================
# 使用方式：
#   1. 複製本檔為 api/.env：
#        Linux/macOS:  cp api/.env.example api/.env
#        Windows:      copy api\.env.example api\.env
#   2. 將下方標示為「請務必修改」的欄位改為自己的安全值。
#   3. 啟動服務：api\start_app.bat（Windows）或 cd api && python app.py（其他）
#
# 注意：本檔（.env.example）可進入版控，但 api/.env 已加入 .gitignore，
#       絕對不要 commit 含真實密鑰的 .env。
# -------------------------------------------------------------------

# ---------- 認證機敏資料（請務必修改） ----------

# JWT 簽章密鑰；建議至少 32 bytes 以上之亂數字串。
# 產生範例：python -c "import secrets; print(secrets.token_urlsafe(48))"
ASR_API_JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

# JWT 演算法（一般保留預設）
ASR_API_JWT_ALGORITHM=HS256

# 預設管理員帳號（首次啟動時自動建立；若 ASR_API_RESET_ADMIN_ON_STARTUP=1
# 則每次啟動會將此密碼套用到 admin 帳號上）。
ASR_API_BOOTSTRAP_ADMIN_USERNAME=admin
ASR_API_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
ASR_API_BOOTSTRAP_ADMIN_NICKNAME=ADMIN

# 啟動時是否強制將 admin 密碼重設為上方 BOOTSTRAP_ADMIN_PASSWORD：
#   1=是（預設，方便重置）
#   0=否（保留手動修改後的密碼）
ASR_API_RESET_ADMIN_ON_STARTUP=1

# ---------- 認證資料庫位置 ----------

# 預設為 api/auth.db；改路徑時請確保父目錄存在。
# ASR_API_AUTH_DB=./auth.db

# ---------- ASR 服務運行設定（非機敏，可保持預設） ----------

# 是否跳過 VAD/ASR 模型初始化（1=跳過，僅供測試 WS 連線）
FASTAPI_SKIP_INIT=0

# 是否進行模型預熱（1=啟用，可降低首次推論延遲）
FASTAPI_WARMUP=1

# faster-whisper 模型大小或本地模型資料夾名稱（相對於專案根目錄）
FASTAPI_ASR_MODEL_SIZE=models

# Streaming 緩衝參數（秒）
BUFFERING_CHUNK_LENGTH_SECONDS=1.5
BUFFERING_CHUNK_OFFSET_SECONDS=0.1

# uvicorn 監聽位址 / 埠
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=5000

# ---------- 標點符號後處理（檔案辨識任務）----------
# 啟用後，File ASR 完成轉錄後會逐 segment 用 zhpr 加上中文標點（，、。？！；）。
# 模型：p208p2002/zh-wiki-punctuation-restore（bert-base-chinese token-classification，
# 約 100MB；CPU/GPU 皆能跑，首次任務觸發時延遲下載並載入）。
# 載入或推論失敗會自動回退原文，不影響任務狀態。
ASR_API_ENABLE_PUNCTUATION=1

# 標點模型 ID；通常無需修改。模型為公開（非 gated），不需要 HF Token。
ASR_API_PUNCTUATION_MODEL=p208p2002/zh-wiki-punctuation-restore

# zhpr 滑窗推論參數：window_size 為單視窗最大字數，stride_step 為視窗間移動量
# （window - step 為相鄰視窗 overlap，留給 merge_stride 平滑邊界）。
ASR_API_PUNCTUATION_WINDOW_SIZE=256
ASR_API_PUNCTUATION_STRIDE_STEP=200

# 一次 forward 同時處理多少視窗。模型約 100MB，batch=8 在 CPU/GPU 都很安全。
ASR_API_PUNCTUATION_BATCH_SIZE=8