# 各元件自己的 venv（main.py 用 venv/；Taiwan-Tongues-ASR-CE 用 train_env/、asr_api/）
venv/
Taiwan-Tongues-ASR-CE/train_env/
Taiwan-Tongues-ASR-CE/asr_api/

# 一次性來源資料（僅用於產生 keywords.json / care_intents.json，不是服務執行期需要的檔案）
ChhoeTaigiDatabase/

# Python 快取
__pycache__/
*.pyc

# main.py 執行期的暫存/本地資料
temp_audio/
care_records.db

# 開發期暫存筆記
scratch_*.txt

# 機敏設定（金鑰、密碼），一律用 .env.example 為範本另行建立
.env
*.env.local

# Claude Code 本機工具設定（跟專案程式碼無關，各人機器不同）
.claude/

# 本機下載的模型權重（數 GB～數十 GB，不進版控；main.py 只用 breeze_asr_model/、m2m100_1.2B/，
# 從 Hugging Face 下載，其餘為比較測試用、已不使用）
Taiwan-Tongues-ASR-CE/breeze_asr_model/
Taiwan-Tongues-ASR-CE/m2m100_1.2B/
Taiwan-Tongues-ASR-CE/nutn_taiwanese_model/
Taiwan-Tongues-ASR-CE/models_fresh_verify/
Taiwan-Tongues-ASR-CE/models/
Taiwan-Tongues-ASR-CE/model_for_finetune/

# 本機測試音檔/語料/暫時腳本與結果（開發期驗證用，非服務必要，體積大）
Taiwan-Tongues-ASR-CE/cer_bench_nan/
Taiwan-Tongues-ASR-CE/cer_bench_zhtw/
Taiwan-Tongues-ASR-CE/ey_psa_audio/
